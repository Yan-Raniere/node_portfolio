<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Configurações — Admin</title>
  <link rel="stylesheet" href="/style/style.css">
  <link rel="stylesheet" href="/style/admin.css">
</head>
<body class="admin-body">

<%- include('../partials/admin-nav') %>

<main class="admin-main">
  <div class="admin-page-header">
    <h1 class="admin-page-title">Configurações</h1>
  </div>

  <div style="max-width:560px;">

    <% if (success) { %>
      <div class="admin-alert" style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);color:#16a34a;padding:14px 18px;border-radius:12px;font-size:14px;font-weight:500;margin-bottom:24px;">
        <%= success %>
      </div>
    <% } %>
    <% if (error) { %>
      <div class="admin-alert admin-alert-error"><%= error %></div>
    <% } %>

    <!-- IMAGENS PADRÃO -->
    <div class="card admin-form-card">
      <h3 class="admin-form-section-title">Imagens Padrão</h3>
      <p style="font-size:13px;color:var(--text3);margin-bottom:20px;">
        Exibida automaticamente quando um post ou projeto não tiver imagem própria.
      </p>

      <form method="POST" action="/admin/configuracoes/imagens" enctype="multipart/form-data">
        <div class="form-field">
          <label>Imagem padrão — Posts</label>
          <input type="hidden" name="remove_default_post_image" id="removePost" value="0">
          <div class="img-upload-zone" id="zonePost" onclick="document.getElementById('inputPost').click()">
            <% if (defaultPostImage) { %>
              <img id="previewPost" src="<%= defaultPostImage %>" alt="Padrão posts">
            <% } else { %>
              <div id="placeholderPost" class="upload-placeholder">
                <span class="upload-icon">📝</span>
                <span>Clique para escolher</span>
                <small>JPG, PNG, WebP — máx. 5MB</small>
              </div>
            <% } %>
          </div>
          <input type="file" id="inputPost" name="default_post_image" accept="image/*" style="display:none">
          <% if (defaultPostImage) { %>
            <button type="button" class="admin-btn-sm danger" style="margin-top:6px;align-self:flex-start;" onclick="removeDefault('Post')">Remover imagem</button>
          <% } %>
        </div>

        <div class="form-field">
          <label>Imagem padrão — Projetos</label>
          <input type="hidden" name="remove_default_project_image" id="removeProj" value="0">
          <div class="img-upload-zone" id="zoneProj" onclick="document.getElementById('inputProj').click()">
            <% if (defaultProjectImage) { %>
              <img id="previewProj" src="<%= defaultProjectImage %>" alt="Padrão projetos">
            <% } else { %>
              <div id="placeholderProj" class="upload-placeholder">
                <span class="upload-icon">🚀</span>
                <span>Clique para escolher</span>
                <small>JPG, PNG, WebP — máx. 5MB</small>
              </div>
            <% } %>
          </div>
          <input type="file" id="inputProj" name="default_project_image" accept="image/*" style="display:none">
          <% if (defaultProjectImage) { %>
            <button type="button" class="admin-btn-sm danger" style="margin-top:6px;align-self:flex-start;" onclick="removeDefault('Proj')">Remover imagem</button>
          <% } %>
        </div>

        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">
          Salvar imagens padrão
        </button>
      </form>
    </div>

    <!-- ALTERAR SENHA -->
    <div class="card admin-form-card" style="margin-top:16px;">
      <h3 class="admin-form-section-title">Alterar Senha</h3>
      <form method="POST" action="/admin/configuracoes/senha">
        <div class="form-field">
          <label>Senha Atual</label>
          <input type="password" name="current_password" required placeholder="••••••••">
        </div>
        <div class="form-field">
          <label>Nova Senha</label>
          <input type="password" name="new_password" required placeholder="Mínimo 6 caracteres">
        </div>
        <div class="form-field">
          <label>Confirmar Nova Senha</label>
          <input type="password" name="confirm_password" required placeholder="Repita a nova senha">
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:4px;">
          Alterar senha
        </button>
      </form>
    </div>

    <!-- USUÁRIO -->
    <div class="card admin-form-card" style="margin-top:16px;">
      <h3 class="admin-form-section-title">Usuário Admin</h3>
      <p style="font-size:14px;color:var(--text2);">
        Usuário: <strong style="color:var(--text)"><%= process.env.ADMIN_USER %></strong>
      </p>
      <span class="admin-hint" style="margin-top:8px;display:block;">
        Para alterar o usuário, edite a variável
        <code style="background:var(--bg);padding:2px 6px;border-radius:4px;font-size:12px;">ADMIN_USER</code>
        no painel da Vercel.
      </span>
    </div>

  </div>
</main>

<script>
  const placeholders = {
    Post: `<div class="upload-placeholder"><span class="upload-icon">📝</span><span>Clique para escolher</span><small>JPG, PNG, WebP — máx. 5MB</small></div>`,
    Proj: `<div class="upload-placeholder"><span class="upload-icon">🚀</span><span>Clique para escolher</span><small>JPG, PNG, WebP — máx. 5MB</small></div>`,
  };

  function bindPreview(suffix, inputId, zoneId) {
    document.getElementById(inputId).addEventListener('change', function (e) {
      const file = e.target.files[0];
      if (!file) return;
      document.getElementById('remove' + suffix).value = '0';
      const reader = new FileReader();
      reader.onload = ev => {
        document.getElementById(zoneId).innerHTML = `<img src="${ev.target.result}" alt="Preview">`;
      };
      reader.readAsDataURL(file);
    });
  }

  function removeDefault(suffix) {
    document.getElementById('remove' + suffix).value = '1';
    document.getElementById('input' + suffix).value = '';
    document.getElementById('zone' + suffix).innerHTML = placeholders[suffix];
  }

  bindPreview('Post', 'inputPost', 'zonePost');
  bindPreview('Proj', 'inputProj', 'zoneProj');
</script>

</body>
</html>
