<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Yan Raniere</title>
  <link rel="stylesheet" href="/style/style.css">
  <link rel="stylesheet" href="/style/admin.css">
</head>
<body class="admin-body">

<div class="login-wrap">
  <div class="login-card card">
    <div class="login-logo">YR<span>.</span></div>
    <h2 class="login-title">Painel Admin</h2>

    <% if (error) { %>
      <div class="admin-alert admin-alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login">
      <div class="form-field">
        <label>Usuário</label>
        <input type="text" name="username" required autofocus placeholder="seu usuário">
      </div>
      <div class="form-field">
        <label>Senha</label>
        <input type="password" name="password" required placeholder="••••••••">
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:8px;">
        Entrar
      </button>
    </form>
  </div>
</div>

</body>
</html>
