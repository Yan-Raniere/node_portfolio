<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Posts — Admin</title>
  <link rel="stylesheet" href="/style/style.css">
  <link rel="stylesheet" href="/style/admin.css">
</head>
<body class="admin-body">

<%- include('../../partials/admin-nav') %>

<main class="admin-main">
  <div class="admin-page-header">
    <h1 class="admin-page-title">Posts do Blog</h1>
    <a href="/admin/posts/novo" class="btn btn-primary">+ Novo Post</a>
  </div>

  <% if (posts.length === 0) { %>
    <div class="card admin-empty-card">
      <p class="admin-empty">Nenhum post ainda. <a href="/admin/posts/novo">Criar o primeiro →</a></p>
    </div>
  <% } else { %>
    <div class="admin-table-wrap card">
      <table class="admin-table">
        <thead>
          <tr><th>Título</th><th>Status</th><th>Tags</th><th>Data</th><th>Ações</th></tr>
        </thead>
        <tbody>
          <% posts.forEach(post => { %>
            <tr>
              <td>
                <strong><%= post.title %></strong>
                <% if (post.excerpt) { %>
                  <div class="admin-sub"><%= post.excerpt.substring(0, 70) %>...</div>
                <% } %>
              </td>
              <td>
                <span class="admin-badge <%= post.published ? 'badge-green' : 'badge-gray' %>">
                  <%= post.published ? 'Publicado' : 'Rascunho' %>
                </span>
              </td>
              <td>
                <div class="admin-tags-mini">
                  <% (post.tags || []).forEach(tag => { %>
                    <span class="pill"><%= tag %></span>
                  <% }) %>
                </div>
              </td>
              <td class="admin-date"><%= new Date(post.created_at).toLocaleDateString('pt-BR') %></td>
              <td>
                <div class="admin-actions">
                  <% if (post.published) { %>
                    <a href="/blog/<%= post.slug %>" target="_blank" class="admin-btn-sm">Ver</a>
                  <% } %>
                  <a href="/admin/posts/<%= post.id %>/editar" class="admin-btn-sm">Editar</a>
                  <form method="POST" action="/admin/posts/<%= post.id %>?_method=DELETE" onsubmit="return confirm('Deletar este post permanentemente?')">
                    <button type="submit" class="admin-btn-sm danger">Deletar</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</main>

</body>
</html>
